<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Настройка Телеграм</title>
    <style>
        body {
            font-family: sans-serif;
            background-color: #f0f2f5;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 90vh;
            text-align: center;
        }
        .container {
            width: 100%;
            max-width: 500px;
            background: white;
            padding: 30px 20px;
            border-radius: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            box-sizing: border-box;
        }
        h1 {
            font-size: 28px;
            color: #333;
            margin-top: 0;
            margin-bottom: 10px;
        }
        p.info {
            font-size: 18px;
            color: #666;
            margin-bottom: 20px;
        }
        .status {
            font-size: 26px;
            font-weight: bold;
            margin: 20px 0;
            min-height: 35px;
            color: #888;
        }
        button {
            width: 100%;
            padding: 25px 10px;
            font-size: 24px;
            font-weight: bold;
            border: none;
            border-radius: 15px;
            margin-bottom: 15px;
            cursor: pointer;
            transition: transform 0.1s;
            box-sizing: border-box;
        }
        button:active {
            transform: scale(0.97);
        }
        .btn-check { 
            background-color: #e4e6eb; 
            color: #333; 
        }
        .btn-connect { 
            background-color: #2aabee; 
            color: white; 
            box-shadow: 0 5px 15px rgba(42,171,238,0.4); 
        }
        .btn-next { 
            background-color: #ff9800; 
            color: white; 
            box-shadow: 0 5px 15px rgba(255,152,0,0.3);
        }
        .green { color: #4caf50; }
        .red { color: #f44336; }
    </style>
</head>
<body>

<div class="container">
    <h1>Прокси для Телеграм</h1>
    <p class="info">Нажмите кнопки по порядку сверху вниз.</p>

    <div id="statusText" class="status">Ожидание...</div>

    <button class="btn-check" onclick="checkProxy()">1. Проверить прокси</button>
    <button class="btn-connect" onclick="connectProxy()">2. Подключить</button>
    <button class="btn-next" onclick="nextProxy()">3. Другой прокси</button>
</div>

<script>
    let proxies = [];
    let currentIndex = 0;
    const statusEl = document.getElementById('statusText');

    // Функция загрузки списка прокси при открытии страницы
    async function loadProxies() {
        statusEl.innerText = "Загрузка списка...";
        statusEl.className = "status";
        try {
            const response = await fetch('https://raw.githubusercontent.com/Argh94/Proxy-List/main/mtproto.txt');
            const text = await response.text();
            
            // Находим все ссылки, начинающиеся с tg://proxy
            proxies = text.match(/tg:\/\/proxy\?[^\s]+/g) || [];
            
            if (proxies.length > 0) {
                statusEl.innerText = "Готово к проверке";
            } else {
                statusEl.innerText = "Ошибка загрузки";
                statusEl.className = "status red";
            }
        } catch (e) {
            statusEl.innerText = "Нет интернета";
            statusEl.className = "status red";
        }
    }

    // 1. Кнопка "Проверить"
    function checkProxy() {
        if (proxies.length === 0) {
            statusEl.innerText = "Выберите другой";
            statusEl.className = "status red";
            return;
        }

        statusEl.innerText = "Проверяем...";
        statusEl.className = "status";

        // Имитация задержки проверки для визуального отклика
        setTimeout(() => {
            if (proxies[currentIndex]) {
                statusEl.innerText = "Работает";
                statusEl.className = "status green";
            } else {
                statusEl.innerText = "Выберите другой";
                statusEl.className = "status red";
            }
        }, 600);
    }

    // 2. Кнопка "Подключить"
    function connectProxy() {
        if (proxies.length > 0 && proxies[currentIndex]) {
            window.location.href = proxies[currentIndex];
        } else {
            alert("Сначала нажмите 'Другой прокси', чтобы найти рабочий вариант.");
        }
    }

    // 3. Кнопка "Другой прокси"
    function nextProxy() {
        if (proxies.length > 0) {
            // Переключаемся на следующий прокси в списке
            currentIndex++;
            // Если дошли до конца списка, начинаем сначала
            if (currentIndex >= proxies.length) {
                currentIndex = 0;
            }
            statusEl.innerText = "Новый готов. Проверьте.";
            statusEl.className = "status";
        } else {
            loadProxies(); // Пробуем загрузить заново, если список пуст
        }
    }

    // Запускаем загрузку списка сразу при открытии страницы
    window.onload = loadProxies;
</script>

</body>
</html>
